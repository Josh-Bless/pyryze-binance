<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  
  <!-- Define an appender that writes logs in XML format to a file -->
  <appender name="FILE" class="ch.qos.logback.core.FileAppender">
    <!-- Specify the file location for your unit test logs -->
    <file>./test-logs/unit-test-log.log</file>
    
        <!-- Use the XMLLayoutEncoder to produce XML formatted logs -->
        <encoder>
            <pattern>[%d{yyyy-MM-dd HH:mm:ss.SS z}] [%c] [%t] [%L] [%-5p] %logger{36} - %msg%n
            </pattern>
        </encoder>
  </appender>
  
  <!-- Root logger configuration -->
  <root level="DEBUG">
    <appender-ref ref="FILE"/>
  </root>
  
</configuration>
